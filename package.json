{
  "name": "ragbot",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@ragbot/api",
    "dev:app": "turbo run dev --filter=@ragbot/app",
    "dev:web": "turbo run dev --filter=@ragbot/web",
    "dev:docs": "turbo run dev --filter=@ragbot/docs",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@ragbot/api",
    "build:app": "turbo run build --filter=@ragbot/app",
    "build:web": "turbo run build --filter=@ragbot/web",
    "build:docs": "turbo run build --filter=@ragbot/docs",
    "lint": "turbo run lint",
    "lint:api": "turbo run lint --filter=@ragbot/api",
    "lint:app": "turbo run lint --filter=@ragbot/app",
    "lint:web": "turbo run lint --filter=@ragbot/web",
    "lint:docs": "turbo run lint --filter=@ragbot/docs",
    "test": "turbo run test",
    "test:api": "turbo run test --filter=@ragbot/api",
    "format": "turbo run format",
    "format:api": "turbo run format --filter=@ragbot/api",
    "format:app": "turbo run format --filter=@ragbot/app",
    "format:web": "turbo run format --filter=@ragbot/web",
    "format:docs": "turbo run format --filter=@ragbot/docs"
  },
  "devDependencies": {
    "pnpm": "^10.33.0",
    "turbo": "^2.9.6"
  }
}
