# application
NODE_ENV=development
PORT=3000

# database
DATABASE_URL=postgresql://pg_user:pg_password@pg_host/pg_database

# JWT — generate random secrets (min 32 chars). ACCESS and REFRESH must differ.
ACCESS_TOKEN_SECRET=changeme_generate_a_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=changeme_generate_a_different_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://api.example.com

# logging
LOG_LEVEL=info
LOG_TO_FILE=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080

# rate limiting
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERAL_MAX=100
