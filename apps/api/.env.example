# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://pg_user:pg_password@pg_host/pg_database

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate random secrets (min 32 chars). ACCESS and REFRESH must differ.
ACCESS_TOKEN_SECRET=changeme_generate_a_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=changeme_generate_a_different_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://api.example.com

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Rate limiting
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERAL_MAX=100

# AI Inference (OpenRouter)
OPENROUTER_API_KEY=
DEFAULT_EMBEDDINGS_MODEL=openai/text-embedding-3-small
DEFAULT_CHAT_MODEL=openai/gpt-5.4-mini
WHISPER_MODEL=openai/whisper-large-v3-turbo  # audio transcription model for YouTube fallback

# Outbound HTTP timeouts in ms — sever a hung upstream so it can't stall a worker/request
OPENROUTER_STREAM_TIMEOUT_MS=60000     # abort a chat stream if no data arrives within this window
OPENROUTER_TIMEOUT_MS=30000            # embeddings + non-streaming chat
OPENROUTER_TRANSCRIBE_TIMEOUT_MS=120000 # Whisper transcription request (audio segments are large)
FIRECRAWL_TIMEOUT_MS=60000             # URL scrape (scrapes can be slow)
LLAMAINDEX_TIMEOUT_MS=30000            # parse-job submit + each poll request
S3_TIMEOUT_MS=10000                    # R2/S3 connection + request timeout

# Email (Brevo — sends inline HTML, no hosted templates needed)
BREVO_API_KEY=
EMAIL_FROM_NAME=RAGBot
EMAIL_FROM_ADDRESS=noreply@example.com

# App URL (used in email links)
APP_URL=http://localhost:8080

# File Storage (Cloudflare R2 — S3-compatible)
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# LlamaIndex Parsing
LLAMAINDEX_API_KEY=
LLAMAINDEX_PARSE_TIER=cost_effective  # fast | cost_effective | agentic | agentic_plus

# Firecrawl
FIRECRAWL_API_KEY=

# YouTube ingestion — transcripts come from yt-dlp captions, else audio + Whisper.
# Defaults resolve yt-dlp/ffmpeg from PATH (installed in the API Docker image); set
# absolute paths only if they live elsewhere. No API key needed.
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
YOUTUBE_AUDIO_SEGMENT_SECONDS=600    # split long audio into N-second chunks for transcription
YOUTUBE_WORKER_CONCURRENCY=1         # parallel transcription jobs (keep low — long & CPU-bound)
YOUTUBE_DOWNLOAD_TIMEOUT_MS=600000   # yt-dlp download + ffmpeg segmentation timeout
YOUTUBE_MAX_DURATION_SECONDS=7200    # reject videos longer than this from the audio+Whisper path (captions exempt)
# yt-dlp --max-filesize cap (backstop for live-stream VODs that report no duration).
# Format: <number><optional single-letter unit>, case-insensitive, units are binary (1024-based):
#   no suffix = bytes (157286400), K = KiB (150K), M = MiB (150M), G = GiB (1.5G), also T/P/E/Z/Y.
# Decimals allowed (44.6M). Single letter ONLY — "150MB"/"150MiB"/trailing "B" are rejected by yt-dlp.
YOUTUBE_MAX_FILESIZE=150M

# Session geolocation (optional) — resolves a session's IP to a "City, CC" label
# shown in the active-sessions list. Disabled by default.
# When IP_GEOLOCATION_ENABLED=true, IPGEOLOCATION_API_KEY is REQUIRED (startup fails
# otherwise). Get a key at https://ipgeolocation.io. Private/loopback IPs always
# resolve to null, so locally-originated sessions never show a location even when enabled.
IP_GEOLOCATION_ENABLED=false
IPGEOLOCATION_API_KEY=
IPGEOLOCATION_TIMEOUT_MS=5000        # lookup timeout in ms
