# Canonical domain — used for og:url, canonical link, and sitemap
PUBLIC_SITE_URL=http://localhost:4321

# App domain — CTA "Sign up free" links to PUBLIC_APP_URL/signup
PUBLIC_APP_URL=http://localhost:8080

# Docs domain — nav + footer "Docs"/"Documentation" links point to PUBLIC_DOCS_URL/
PUBLIC_DOCS_URL=http://localhost:4173
