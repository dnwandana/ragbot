---
const appUrl = import.meta.env.PUBLIC_APP_URL
---

<section class="final-cta">
  <div class="wrap">
    <div class="cta-panel reveal" data-d="1">
      <h2 class="sec-title">Ready to talk to your documents?</h2>
      <p class="lead">
        Set up your first workspace in minutes. Ask your first question before your coffee gets
        cold.
      </p>
      <a class="btn btn-primary btn-lg" href={`${appUrl}/signup`}>Sign up free</a>
    </div>
  </div>
</section>
