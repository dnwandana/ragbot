---
import { ShieldCheck, Lock, LayoutGrid, Users } from "@lucide/astro"
---

<section class="section-pad" id="why">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow reveal">Why people love it</span>
      <h2 class="sec-title reveal" data-d="1">Answers you can actually trust.</h2>
      <p class="lead reveal" data-d="2">
        Built to feel calm and dependable — like a helpful librarian who's read everything for you.
      </p>
    </div>
    <div class="cards">
      <article class="card reveal" data-d="1">
        <div class="card-ico ico-brand"><ShieldCheck size={24} stroke-width={1.6} /></div>
        <h3>Every answer is sourced</h3>
        <p>
          Each reply shows exactly where it came from — the file and the page — so you never have to
          take our word for it. Tap to read it yourself.
        </p>
      </article>
      <article class="card reveal" data-d="2">
        <div class="card-ico ico-sage"><Lock size={24} stroke-width={1.6} /></div>
        <h3>Private by design</h3>
        <p>
          Your documents live in your own space. Your data stays yours — never shared, never mixed
          with anyone else's.
        </p>
      </article>
      <article class="card reveal" data-d="3">
        <div class="card-ico ico-brand"><LayoutGrid size={24} stroke-width={1.6} /></div>
        <h3>Organized your way</h3>
        <p>
          Group files into separate workspaces so each project, client, or topic stays neatly apart
          — and answers never wander off-topic.
        </p>
      </article>
      <article class="card reveal" data-d="4">
        <div class="card-ico ico-sage"><Users size={24} stroke-width={1.6} /></div>
        <h3>Bring your team<span class="opt-tag">When ready</span></h3>
        <p>
          Working solo today? Perfect. Invite people whenever you're ready, and stay in control of
          who can see what.
        </p>
      </article>
    </div>
  </div>
</section>
