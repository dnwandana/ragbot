---
import IconUpload from "../icons/IconUpload.astro"
import IconFolder from "../icons/IconFolder.astro"
import IconMessage from "../icons/IconMessage.astro"
---

<section class="section-pad band-beige" id="how">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow reveal">How it works</span>
      <h2 class="sec-title reveal" data-d="1">Three easy steps. No manual required.</h2>
      <p class="lead reveal" data-d="2">
        If you can send a text message, you already know how to use RAGBot.
      </p>
    </div>
    <div class="steps">
      <div class="step reveal" data-d="1">
        <div class="step-ico"><IconUpload /></div>
        <div class="step-num"></div>
        <h3>Drop in your files</h3>
        <p>
          Add your PDFs, docs, and notes. We tuck them into tidy collections for you — no setup, no
          sorting.
        </p>
      </div>
      <div class="step reveal" data-d="2">
        <div class="step-ico"><IconFolder /></div>
        <div class="step-num"></div>
        <h3>Keep things tidy</h3>
        <p>
          Give each project, client, or topic its own space, so the answers you get always stay on
          point.
        </p>
      </div>
      <div class="step reveal" data-d="3">
        <div class="step-ico"><IconMessage /></div>
        <div class="step-num"></div>
        <h3>Just ask</h3>
        <p>
          Type a question like you'd ask a person. Get a clear answer back — with the exact source
          it came from.
        </p>
      </div>
    </div>
  </div>
</section>
