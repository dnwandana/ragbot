---
import { Check } from "@lucide/astro"
---

<section class="section-pad band-beige reassure-band">
  <div class="wrap">
    <h2 class="sec-title reveal" data-d="1">It's easy. It's private. It just works.</h2>
    <p class="reveal" data-d="2">
      No new app to learn, nothing technical to figure out. Add your files, ask your question, get a
      straight answer with its source. That's the whole thing.
    </p>
    <div class="trust-row reveal" data-d="3">
      <span><Check size={19} stroke-width={1.8} />Ready in minutes</span>
      <span><Check size={19} stroke-width={1.8} />No jargon, ever</span>
      <span><Check size={19} stroke-width={1.8} />Your data stays yours</span>
    </div>
  </div>
</section>
