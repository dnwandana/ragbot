---
import IconSun from "../icons/IconSun.astro"
import IconMoon from "../icons/IconMoon.astro"
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-copy">© 2026 RAGBot. Made for people with a lot to read.</div>
    <button
      id="theme-toggle"
      class="theme-toggle"
      title="Switch to dark mode"
      aria-label="Switch to dark mode"
    >
      <span class="icon-sun"><IconSun /></span>
      <span class="icon-moon"><IconMoon /></span>
    </button>
  </div>
</footer>
