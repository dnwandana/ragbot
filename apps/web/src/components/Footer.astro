---
import { Sun, Moon } from "@lucide/astro"

const docsUrl = import.meta.env.PUBLIC_DOCS_URL
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-left">
      <span class="footer-copy">© {year} RAGBot. Made for people with a lot to read.</span>
      <a class="footer-link" href={`${docsUrl}/`}>Documentation</a>
    </div>
    <button
      id="theme-toggle"
      class="theme-toggle"
      title="Switch to dark mode"
      aria-label="Switch to dark mode"
    >
      <span class="icon-sun"><Sun size={18} stroke-width={1.7} /></span>
      <span class="icon-moon"><Moon size={18} stroke-width={1.7} /></span>
    </button>
  </div>
</footer>
