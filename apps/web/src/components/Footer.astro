---
import { Sun, Moon } from "@lucide/astro"
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-copy">© 2026 RAGBot. Made for people with a lot to read.</div>
    <button
      id="theme-toggle"
      class="theme-toggle"
      title="Switch to dark mode"
      aria-label="Switch to dark mode"
    >
      <span class="icon-sun"><Sun size={18} stroke-width={1.7} /></span>
      <span class="icon-moon"><Moon size={18} stroke-width={1.7} /></span>
    </button>
  </div>
</footer>
