# === Deployment domain (drives docker-compose.yml nginx + frontend build args) ===
# Set to your registrable domain. The production compose derives:
#   <DOMAIN>       → marketing site (apps/web)
#   app.<DOMAIN>   → SPA (apps/app)         build arg PUBLIC_APP_URL / VITE target
#   api.<DOMAIN>   → API (apps/api)         build arg VITE_API_BASE_URL=https://api.<DOMAIN>
DOMAIN=yourdomain.com

# === App (build-time) ===
# In the production stack, VITE_API_BASE_URL is derived from DOMAIN by
# docker-compose.yml (https://api.<DOMAIN>) — no need to set it here.
# Override only for non-Docker local dev (default: http://localhost:3000/api).

# === API (runtime) ===
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
ACCESS_TOKEN_SECRET=changeme_generate_a_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=changeme_generate_a_different_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=https://api.yourdomain.com
JWT_AUDIENCE=https://app.yourdomain.com
LOG_LEVEL=info
LOG_TO_FILE=false
# Must list the SPA origin exactly (credentialed CORS — no wildcard).
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERAL_MAX=100
# Frontend origin — used to build email verification / reset links.
APP_URL=https://app.yourdomain.com
BREVO_API_KEY=
EMAIL_FROM_NAME=RAGBot
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
OPENROUTER_API_KEY=
DEFAULT_EMBEDDINGS_MODEL=openai/text-embedding-3-small
DEFAULT_CHAT_MODEL=openai/gpt-5.4-mini
# Streaming timeout in milliseconds for OpenRouter chat completions (default: 60000).
OPENROUTER_STREAM_TIMEOUT_MS=60000
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
LLAMAINDEX_API_KEY=
# Parsing tier for LlamaIndex document parsing (fast | cost_effective | agentic | agentic_plus).
LLAMAINDEX_PARSE_TIER=cost_effective
FIRECRAWL_API_KEY=

# Session geolocation (optional) — resolves a session's IP to a "City, CC" label
# on the active-sessions list. Disabled by default. Set IP_GEOLOCATION_ENABLED=true
# AND provide IPGEOLOCATION_API_KEY — the key is REQUIRED when enabled (startup fails
# otherwise; get one at https://ipgeolocation.io).
IP_GEOLOCATION_ENABLED=false
IPGEOLOCATION_API_KEY=
IPGEOLOCATION_TIMEOUT_MS=5000

# Redis (BullMQ queue) — redis:// for plain, rediss:// for TLS.
REDIS_URL=redis://localhost:6379
