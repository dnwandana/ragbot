# === App (build-time — Vite bakes this into the bundle) ===
VITE_API_BASE_URL=/api

# === API (runtime) ===
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
ACCESS_TOKEN_SECRET=changeme_generate_a_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=changeme_generate_a_different_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=https://yourdomain.com
JWT_AUDIENCE=https://yourdomain.com
LOG_LEVEL=info
LOG_TO_FILE=false
CORS_ALLOWED_ORIGINS=https://yourdomain.com
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERAL_MAX=100
APP_URL=https://yourdomain.com
BREVO_API_KEY=
EMAIL_FROM_NAME=RAG Chatbot
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
OPENROUTER_API_KEY=
DEFAULT_EMBEDDINGS_MODEL=openai/text-embedding-3-small
DEFAULT_CHAT_MODEL=openai/gpt-4.1
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
LLAMAINDEX_API_KEY=
LLAMAINDEX_WEBHOOK_SECRET=
FIRECRAWL_API_KEY=
