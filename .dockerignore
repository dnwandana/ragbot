# Build context exclusions — context is the repo root for every Dockerfile.
**/node_modules
**/dist
**/.astro
**/.turbo
.git
.gitignore
**/.env
**/.env.*
!**/.env.example
certs/
docs/
plans/
*.md
**/*.md
# apps/docs is a VitePress site — its content IS markdown, so keep it in the build context
!apps/docs/**/*.md

# test artifacts
coverage

# editor
.vscode
.idea

# local tooling caches
.pnpm-store/
.corepack/

# playwright
.playwright-cli/
.playwright-mcp/

# coding agents
.agents/
.claude/
skills-lock.json
